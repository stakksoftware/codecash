{
  "name": "codecash",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "codecash",
      "version": "0.1.0",
      "license": "MIT",
      "workspaces": [
        "packages/*",
        "apps/*"
      ],
      "bin": {
        "codecash": "apps/cli/bin/codecash.js"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "apps/cli": {
      "name": "@codecash/cli",
      "version": "0.1.0",
      "license": "MIT",
      "dependencies": {
        "@codecash/core": "0.1.0"
      },
      "bin": {
        "codecash": "bin/codecash.js"
      }
    },
    "apps/server": {
      "name": "@codecash/server",
      "version": "0.1.0",
      "license": "MIT",
      "dependencies": {
        "@codecash/core": "0.1.0"
      }
    },
    "node_modules/@codecash/cli": {
      "resolved": "apps/cli",
      "link": true
    },
    "node_modules/@codecash/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@codecash/server": {
      "resolved": "apps/server",
      "link": true
    },
    "packages/core": {
      "name": "@codecash/core",
      "version": "0.1.0",
      "license": "MIT"
    }
  }
}
